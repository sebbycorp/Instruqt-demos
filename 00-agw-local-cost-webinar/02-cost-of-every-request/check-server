#!/bin/bash
set -uo pipefail

if ! docker ps --format '{{.Names}}' | grep -q '^agentgateway$'; then
  fail-message "The agentgateway container isn't running. Run: agw-up"
  exit 1
fi

if [ ! -f /root/data/data.db ]; then
  fail-message "No request log yet at /root/data/data.db. Send some traffic to :4000 first (Step 1)."
  exit 1
fi

n=$(sqlite3 /root/data/data.db "SELECT COUNT(*) FROM request_logs WHERE cost > 0;" 2>/dev/null || echo 0)
if ! [ "$n" -ge 1 ] 2>/dev/null; then
  fail-message "No priced requests found in request_logs. Run the Step 1 loop to send completions through :4000, then check again."
  exit 1
fi

echo "Found $n priced request(s) in the log — cost tracking works."
