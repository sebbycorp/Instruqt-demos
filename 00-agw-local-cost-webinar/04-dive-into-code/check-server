#!/bin/bash
set -uo pipefail
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"

if ! docker ps --format '{{.Names}}' | grep -q '^agentgateway$'; then
  fail-message "The agentgateway container isn't running. Run: agw-up"
  exit 1
fi
if ! docker ps --format '{{.Names}}' | grep -q '^mcp-custom$'; then
  fail-message "Your MCP server 'mcp-custom' isn't running. Run: mcp-up"
  exit 1
fi
if [ ! -f /root/app/app.py ]; then
  fail-message "No /root/app/app.py yet. Write the client app from Step 1."
  exit 1
fi

out=$(uv run --with openai --with 'mcp==1.12.4' /root/app/app.py 2>&1)
rc=$?
if [ "$rc" != "0" ]; then
  fail-message "The app exited with an error. Run it yourself to see why: uv run --with openai --with 'mcp==1.12.4' /root/app/app.py"
  echo "$out" | tail -15
  exit 1
fi

if ! echo "$out" | grep -q "estimate_tokens result ->"; then
  fail-message "The app ran but didn't print the tool result. Make sure use_tools() calls estimate_tokens and main() prints it."
  echo "$out" | tail -15
  exit 1
fi

echo "Client app works — it reached OpenAI and your MCP tool through the one gateway."
