#!/bin/bash
set -uo pipefail

if ! docker ps --format '{{.Names}}' | grep -q '^agentgateway$'; then
  fail-message "The agentgateway container isn't running. Run: agw-up"
  exit 1
fi
if ! grep -q "localRateLimit" /root/config.yaml || ! grep -q "type: tokens" /root/config.yaml; then
  fail-message "No token budget found. Add a localRateLimit with 'type: tokens' under llm.policies, then agw-reload."
  exit 1
fi

saw429=0
for i in $(seq 1 10); do
  code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:4000/v1/chat/completions \
    -H "Content-Type: application/json" \
    -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"Write a detailed paragraph about cloud cost governance and FinOps."}],"max_tokens":120}')
  [ "$code" = "429" ] && { saw429=1; break; }
done

if [ "$saw429" != "1" ]; then
  fail-message "Sent 10 requests but never hit a 429. Is maxTokens small (~300) and did you agw-reload?"
  exit 1
fi
echo "Token budget is enforcing — over-budget requests get 429."
