#!/bin/bash
set -euo pipefail
source /root/agw-helpers.sh
export OPENAI_API_KEY="$(cat /root/.openai-api-key 2>/dev/null || echo "${OPENAI_API_KEY:-}")"
mkdir -p /root/costs /root/data /root/mcp-server

# Start from the Lab 2 end-state: gateway routing OpenAI, no MCP yet.
cat > /root/config.yaml <<'YAML'
# yaml-language-server: $schema=https://agentgateway.dev/schema/config
config:
  adminAddr: "0.0.0.0:15000"
  database:
    url: "sqlite:///data/data.db"
  modelCatalog:
    - file: /costs/base-costs.json
llm:
  port: 4000
  policies:
    cors:
      allowOrigins: ["*"]
      allowHeaders: ["*"]
      allowMethods: ["GET","POST","OPTIONS"]
  models:
  - name: "openai/*"
    provider: openAI
    params:
      model: gpt-4.1-nano
      apiKey: "$OPENAI_API_KEY"
frontendPolicies:
  http:
    maxBufferSize: 33554432
YAML

# Seed a starter server.py with a TODO so the Editor opens something to complete.
if [ ! -f /root/mcp-server/server.py ]; then
cat > /root/mcp-server/server.py <<'PY'
from mcp.server.fastmcp import FastMCP

# Bind to all interfaces on :8000 so the gateway container can reach us by name.
mcp = FastMCP("solo-tools", host="0.0.0.0", port=8000)

# TODO: add at least one @mcp.tool() function here (see the assignment).

if __name__ == "__main__":
    mcp.run(transport="streamable-http")
PY
fi

agw-up >/dev/null 2>&1 || true
docker rm -f mcp-custom >/dev/null 2>&1 || true
echo "lab 03 setup complete"
