#!/bin/bash
set -uo pipefail

if ! docker ps --format '{{.Names}}' | grep -q '^agentgateway$'; then
  fail-message "The agentgateway container isn't running. Start it with the docker run command in Step 1 (or: agw-up)."
  exit 1
fi

code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:15000/ui/ 2>/dev/null || echo 000)
if [ "$code" = "000" ]; then
  fail-message "The UI on :15000 isn't answering yet. Give the container a few seconds, then check again (docker logs agentgateway)."
  exit 1
fi

echo "Gateway container is up and the UI on :15000 is answering (HTTP $code)."
