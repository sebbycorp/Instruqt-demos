#!/bin/bash
set -uo pipefail

if ! docker ps --format '{{.Names}}' | grep -q '^agentgateway$'; then
  fail-message "The agentgateway container isn't running. Run: agw-up"
  exit 1
fi

code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:4000/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"ping"}],"max_tokens":5}')
if [ "$code" != "200" ]; then
  fail-message "A call to :4000 returned HTTP $code. Add an llm.models entry (name: \"openai/*\", provider: openAI, params.apiKey: \$OPENAI_API_KEY), then agw-reload."
  exit 1
fi

echo "OpenAI is wired in — :4000 is routing and the call was priced in the log."
