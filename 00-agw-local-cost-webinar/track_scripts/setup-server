#!/bin/bash

# Wait for instruqt bootstrap
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
  sleep 1
done

set -euo pipefail
set-workdir /root

AGW_IMAGE="cr.agentgateway.dev/agentgateway:v1.3.1"
PY_IMAGE="python:3.12-slim"

# ---------------------------------------------------------------------------
# 1. Store the OpenAI key so every script can reach it. Instruqt check/solve
#    scripts run non-interactively and do NOT source ~/.bashrc, so we persist
#    the key to a file too.
# ---------------------------------------------------------------------------
if [ -n "${OPENAI_API_KEY:-}" ]; then
  echo "export OPENAI_API_KEY=${OPENAI_API_KEY}" >> ~/.bashrc
  echo "${OPENAI_API_KEY}" > /root/.openai-api-key
  echo "=== OpenAI API key stored ==="
else
  echo "=== WARNING: OPENAI_API_KEY not set ==="
fi

# ---------------------------------------------------------------------------
# 2. Tooling: jq + sqlite3 for cost queries, uv to run the Python client app.
# ---------------------------------------------------------------------------
command -v jq      >/dev/null 2>&1 || { apt-get update -y >/dev/null 2>&1 && apt-get install -y jq      >/dev/null 2>&1; } || true
command -v sqlite3 >/dev/null 2>&1 || { apt-get update -y >/dev/null 2>&1 && apt-get install -y sqlite3 >/dev/null 2>&1; } || true
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh || true
fi
ln -sf "$HOME/.local/bin/uv"  /usr/local/bin/uv  2>/dev/null || true
ln -sf "$HOME/.local/bin/uvx" /usr/local/bin/uvx 2>/dev/null || true

# ---------------------------------------------------------------------------
# 3. Working dirs + the model cost catalog (USD per 1,000,000 tokens).
# ---------------------------------------------------------------------------
mkdir -p /root/costs /root/data /root/mcp-server /root/app
cat > /root/costs/base-costs.json <<'JSON'
{
  "providers": {
    "anthropic": {
      "models": {
        "claude-3-5-haiku-latest": { "rates": { "input": "0.8", "output": "4", "cacheRead": "0.08", "cacheWrite": "1" } },
        "claude-haiku-4-5": { "rates": { "input": "1", "output": "5", "cacheRead": "0.1", "cacheWrite": "1.25" } },
        "claude-opus-4-1": { "rates": { "input": "15", "output": "75", "cacheRead": "1.5", "cacheWrite": "18.75" } },
        "claude-sonnet-4-5": { "rates": { "input": "3", "output": "15", "cacheRead": "0.3", "cacheWrite": "3.75" } }
      }
    },
    "openai": {
      "models": {
        "gpt-3.5-turbo": { "rates": { "input": "0.5", "output": "1.5", "cacheRead": "0" } },
        "gpt-4": { "rates": { "input": "30", "output": "60" } },
        "gpt-4-turbo": { "rates": { "input": "10", "output": "30" } },
        "gpt-4.1": { "rates": { "input": "2", "output": "8", "cacheRead": "0.5" } },
        "gpt-4.1-mini": { "rates": { "input": "0.4", "output": "1.6", "cacheRead": "0.1" } },
        "gpt-4.1-nano": { "rates": { "input": "0.1", "output": "0.4", "cacheRead": "0.025" } },
        "gpt-4o": { "rates": { "input": "2.5", "output": "10", "cacheRead": "1.25" } },
        "gpt-4o-mini": { "rates": { "input": "0.15", "output": "0.6", "cacheRead": "0.075" } },
        "gpt-5": { "rates": { "input": "1.25", "output": "10", "cacheRead": "0.125" } },
        "gpt-5-mini": { "rates": { "input": "0.25", "output": "2", "cacheRead": "0.025" } },
        "gpt-5-nano": { "rates": { "input": "0.05", "output": "0.4", "cacheRead": "0.005" } },
        "o3": { "rates": { "input": "2", "output": "8", "cacheRead": "0.5" } },
        "o4-mini": { "rates": { "input": "1.1", "output": "4.4", "cacheRead": "0.275" } }
      }
    }
  }
}
JSON
echo "base-costs.json provisioned: $(wc -c < /root/costs/base-costs.json) bytes"

# ---------------------------------------------------------------------------
# 4. Docker network + images. The gateway and the (later, learner-built) MCP
#    server share agw-net so they resolve each other by name.
# ---------------------------------------------------------------------------
docker network create agw-net >/dev/null 2>&1 || true
echo "=== Pulling images ==="
docker pull "$AGW_IMAGE" >/dev/null 2>&1 || echo "WARN: could not pre-pull $AGW_IMAGE"
docker pull "$PY_IMAGE"  >/dev/null 2>&1 || echo "WARN: could not pre-pull $PY_IMAGE"

# Pre-build a small image with the MCP SDK installed so the MCP server (Lab 3)
# starts instantly and restarts fast after edits.
cat > /root/.mcp-python.Dockerfile <<'DOCKER'
FROM python:3.12-slim
RUN pip install --no-cache-dir "mcp==1.12.4"
WORKDIR /app
DOCKER
echo "=== Building mcp-python:local ==="
docker build -t mcp-python:local -f /root/.mcp-python.Dockerfile /root >/dev/null 2>&1 || echo "WARN: mcp-python:local build failed"

# ---------------------------------------------------------------------------
# 5. Shared helpers — same agw-* / mcp-* commands in the terminal (via
#    ~/.bashrc) and in the non-interactive check/solve scripts (via source).
# ---------------------------------------------------------------------------
cat > /root/agw-helpers.sh <<'HELP'
# Agentgateway local helpers — shared by the terminal and the lab scripts.
export AGW_IMAGE="cr.agentgateway.dev/agentgateway:v1.3.1"

_agw_key() { echo "${OPENAI_API_KEY:-$(cat /root/.openai-api-key 2>/dev/null)}"; }

# Validate /root/config.yaml. The OpenAI key must be passed in: agentgateway
# resolves apiKey "$OPENAI_API_KEY" at parse time even with --validate-config.
agw-validate() {
  docker run --rm \
    -e OPENAI_API_KEY="$(_agw_key)" \
    -v /root/config.yaml:/config.yaml \
    -v /root/costs:/costs \
    "$AGW_IMAGE" -f /config.yaml --validate-config
}

# (Re)create the gateway container from /root/config.yaml.
agw-up() {
  docker rm -f agentgateway >/dev/null 2>&1 || true
  docker run -d --name agentgateway --network agw-net --restart unless-stopped \
    -e OPENAI_API_KEY="$(_agw_key)" \
    -v /root/config.yaml:/config.yaml \
    -v /root/costs:/costs \
    -v /root/data:/data \
    -p 4000:4000 -p 3000:3000 -p 15000:15000 \
    "$AGW_IMAGE" -f /config.yaml >/dev/null
  sleep 4
  echo "agentgateway up — LLM :4000  MCP :3000  UI :15000"
}

# Pick up an edited config WITHOUT recreating the container (config is mounted).
agw-reload() { docker restart agentgateway >/dev/null && sleep 3 && echo "agentgateway reloaded"; }
agw-restart() { agw-up; }
agw-logs()   { docker logs -f agentgateway; }
agw-down()   { docker rm -f agentgateway >/dev/null 2>&1 || true; echo "agentgateway stopped"; }

# (Re)create the learner's MCP server container from /root/mcp-server/server.py.
mcp-up() {
  docker rm -f mcp-custom >/dev/null 2>&1 || true
  docker run -d --name mcp-custom --network agw-net --restart unless-stopped \
    -v /root/mcp-server:/app \
    mcp-python:local python /app/server.py >/dev/null
  sleep 3
  echo "mcp-custom up on agw-net (http://mcp-custom:8000/mcp)"
}
mcp-logs() { docker logs -f mcp-custom; }
mcp-down() { docker rm -f mcp-custom >/dev/null 2>&1 || true; echo "mcp-custom stopped"; }
HELP

if ! grep -q "agw-helpers.sh" ~/.bashrc 2>/dev/null; then
  echo 'source /root/agw-helpers.sh' >> ~/.bashrc
fi

echo "=== track setup complete ==="
