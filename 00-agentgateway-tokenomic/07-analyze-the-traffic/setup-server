#!/bin/bash
set -uo pipefail
# Seed a week of realistic traffic into the gateway's request DB. We do this here
# (a challenge script, $HOME=/root) rather than track setup, where $HOME is unreliable
# and `uv run` may not resolve. uv auto-provisions Python >=3.11 per the generator's
# PEP 723 header — do NOT pass --python (let the header drive it).
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"
command -v uv >/dev/null 2>&1 || { curl -LsSf https://astral.sh/uv/install.sh | sh; ln -sf "$HOME/.local/bin/uv" /usr/local/bin/uv 2>/dev/null || true; }

DB=/root/agentgateway/data/data.db
mkdir -p /root/agentgateway/data
rows=$(sqlite3 "$DB" 'SELECT COUNT(*) FROM request_logs;' 2>/dev/null || echo 0)
if [ "${rows:-0}" -lt 100 ]; then
  echo "seeding mock traffic (rows=$rows)"
  # Append directly into the gateway's live DB (SQLite WAL allows concurrent append).
  # The generator's CREATE TABLE IF NOT EXISTS makes this safe whether or not the
  # gateway already created request_logs.
  uv run /root/agentgateway/gen-mock-logs.py --append --requests 5000 --days 7 --seed 7 -o "$DB" \
    || echo "WARNING: mock-log seed failed"
  chmod -R 777 /root/agentgateway/data
fi
echo "challenge 4 setup complete (rows=$(sqlite3 "$DB" 'SELECT COUNT(*) FROM request_logs;' 2>/dev/null || echo 0))"
