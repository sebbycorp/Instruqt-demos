#!/bin/bash
set -uo pipefail
DB=/root/agentgateway/data/data.db
if [ ! -f "$DB" ]; then
  fail-message "No request database at $DB. Ensure config.database is sqlite:////config/data/data.db and the gateway restarted."
  exit 1
fi
# Drive a priced request, then poll the DB for a row with cost > 0 (avoids write races).
curl -s -o /dev/null http://localhost:4000/v1/chat/completions -H 'Content-Type: application/json' \
  -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"ping"}],"max_tokens":5}' 2>/dev/null
n=0
for i in $(seq 1 15); do
  n=$(sqlite3 "$DB" "SELECT COUNT(*) FROM request_logs WHERE cost > 0;" 2>/dev/null || echo 0)
  [ "${n:-0}" -ge 1 ] && break
  sleep 1
done
if [ "${n:-0}" -lt 1 ]; then
  fail-message "No priced requests recorded yet. Send a request through :4000; the base-costs.json catalog should populate the cost column in $DB."
  exit 1
fi
echo "Cost tracking is live — requests are priced (USD) and logged to the database."
