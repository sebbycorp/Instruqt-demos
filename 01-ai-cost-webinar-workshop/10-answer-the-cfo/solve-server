#!/bin/bash
set -euo pipefail
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"
cd /root
# Append a representative fleet-week into the gateway's OWN database so the UI
# Costs/Analytics pages render it too (the UI reads config.database).
uv run /root/gen-mock-logs.py --append --requests 5000 --days 7 -o /root/data/data.db
echo "=== Spend by team (chargeback) ==="
sqlite3 -box /root/data/data.db "SELECT agentgateway_group AS team, ROUND(SUM(cost),2) AS usd, COUNT(*) AS reqs FROM request_logs GROUP BY team ORDER BY usd DESC;"
echo "=== Spend by provider (incl. Claude) ==="
sqlite3 -box /root/data/data.db "SELECT gen_ai_provider_name AS provider, ROUND(SUM(cost),2) AS usd, COUNT(*) AS reqs FROM request_logs GROUP BY provider ORDER BY usd DESC;"
echo "=== Top 5 spenders ==="
sqlite3 -box /root/data/data.db "SELECT agentgateway_user AS user, ROUND(SUM(cost),2) AS usd FROM request_logs GROUP BY user ORDER BY usd DESC LIMIT 5;"
echo "=== Spend by calling client/agent ==="
sqlite3 -box /root/data/data.db "SELECT json_extract(attributes_json,'\$.\"user_agent.name\"') AS client, COUNT(*) AS reqs, ROUND(SUM(cost),2) AS usd FROM request_logs GROUP BY client ORDER BY usd DESC LIMIT 8;"
echo "=== Batch vs interactive (the mystery) ==="
sqlite3 -box /root/data/data.db "SELECT json_extract(attributes_json,'\$.workload') AS workload, COUNT(*) AS n, ROUND(SUM(cost),2) AS usd FROM request_logs GROUP BY workload ORDER BY usd DESC;"
