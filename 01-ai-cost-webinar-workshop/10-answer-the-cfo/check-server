#!/bin/bash
set -uo pipefail
n=$(sqlite3 /root/data/data.db "SELECT COUNT(*) FROM request_logs;" 2>/dev/null || echo 0)
if [ "${n:-0}" -lt 4000 ]; then
  fail-message "Fleet data not loaded yet. Append a week into your gateway DB: uv run /root/gen-mock-logs.py --append --requests 5000 --days 7 -o /root/data/data.db"
  exit 1
fi
prov=$(sqlite3 /root/data/data.db "SELECT COUNT(DISTINCT gen_ai_provider_name) FROM request_logs;" 2>/dev/null || echo 0)
if [ "${prov:-0}" -lt 2 ]; then
  fail-message "Expected a multi-provider fleet (OpenAI, Anthropic, Google, ...). Re-run the generator with --append."
  exit 1
fi
echo "Fleet loaded ($n requests across $prov providers). You can answer 'who spent the money?'"
