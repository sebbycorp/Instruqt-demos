#!/bin/bash
set -uo pipefail
if [ ! -f /root/data/data.db ]; then
  fail-message "No request database at /root/data/data.db. Ensure config.database is set and the gateway restarted."
  exit 1
fi
# Drive a priced request, then poll the DB for a row with cost (avoids write races).
curl -s http://localhost:4000/v1/chat/completions -H 'Content-Type: application/json' \
  -d '{"model":"openai/gpt-4o-mini","messages":[{"role":"user","content":"ping"}],"max_tokens":5}' >/dev/null 2>&1
n=0
for i in $(seq 1 12); do
  n=$(sqlite3 /root/data/data.db "SELECT COUNT(*) FROM request_logs WHERE cost > 0;" 2>/dev/null || echo 0)
  [ "${n:-0}" -ge 1 ] && break
  sleep 1
done
if [ "${n:-0}" -lt 1 ]; then
  fail-message "No priced requests recorded yet. Send a request through :4000; the default base-costs.json catalog should populate the cost column in /root/data/data.db."
  exit 1
fi
echo "Cost tracking is live — requests are priced (USD) and logged to the database."
