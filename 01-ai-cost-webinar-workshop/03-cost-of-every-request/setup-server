#!/bin/bash
set -euo pipefail
mkdir -p /root/data /root/costs
if [ ! -s /root/costs/base-costs.json ]; then
cat > /root/costs/base-costs.json <<'JSON'
{ "providers": { "openai": { "models": {
  "gpt-4o-mini":  { "rates": { "input": "0.15", "output": "0.60" } },
  "gpt-4o":       { "rates": { "input": "2.50", "output": "10.00" } },
  "gpt-4.1":      { "rates": { "input": "2.00", "output": "8.00" } },
  "gpt-4.1-mini": { "rates": { "input": "0.40", "output": "1.60" } } } } } }
JSON
fi
# Ensure the OpenAI CLI is installed for this challenge's terminal (the openai 2.x
# package ships no CLI, so pin <2). Idempotent; no-op if already present.
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"
command -v openai >/dev/null 2>&1 || { uv tool install 'openai<2' >/dev/null 2>&1 || true; ln -sf "$HOME/.local/bin/openai" /usr/local/bin/openai 2>/dev/null || true; }
echo "challenge 3 setup complete"
