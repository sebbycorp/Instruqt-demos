#!/bin/bash
set -euo pipefail
command -v agentgateway >/dev/null 2>&1 || { curl -sL https://agentgateway.dev/install | bash -s -- --version 1.3.1; }
mkdir -p /root/data /root/costs
# Cost catalog (/root/costs/base-costs.json) is provisioned by track_scripts/setup-server.

# Pre-seed a MINIMAL config so it opens in the Editor (no models yet). The gateway
# is NOT started here — the learner starts it and adds a model (UI or YAML).
if [ ! -f /root/config.yaml ]; then
cat > /root/config.yaml <<'YAML'
# Minimal Agentgateway config — boots the gateway + UI with no models yet.
# Add your OpenAI model in the UI (Models -> Add model), or paste the block from the assignment.
config:
  adminAddr: "0.0.0.0:15000"
  database:
    url: "sqlite:///root/data/data.db"
  modelCatalog:
    - file: /root/costs/base-costs.json
llm:
  port: 4000
  policies:
    cors:
      allowOrigins: ["*"]
      allowHeaders: ["*"]
      allowMethods: ["GET","POST","OPTIONS"]
  models: []
  providers: []
  virtualModels: []
frontendPolicies:
  http:
    maxBufferSize: 33554432
YAML
fi
echo "challenge 2 setup complete"
