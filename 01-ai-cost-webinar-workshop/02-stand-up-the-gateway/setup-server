#!/bin/bash
set -euo pipefail
command -v agentgateway >/dev/null 2>&1 || { curl -sL https://agentgateway.dev/install | bash -s -- --version 1.3.1; }

# Pre-create /root/config.yaml so it appears in the Editor tab (no "new file"
# step needed). The learner reviews/edits it, then validates and starts the
# gateway. We intentionally do NOT start the gateway here — that's the learner's
# (or the solve script's) job, so the challenge check is meaningful.
if [ ! -f /root/config.yaml ]; then
cat > /root/config.yaml <<'YAML'
# Agentgateway — your first AI gateway.
# Listens on :4000, authenticates to OpenAI, and forwards /v1/* requests.
# Review this, then: agentgateway -f /root/config.yaml --validate-only
config:
  # Expose the admin UI (:15000/ui) on all interfaces so the lab's UI tab can reach it.
  adminAddr: "0.0.0.0:15000"
binds:
- port: 4000
  listeners:
  - protocol: HTTP
    routes:
    - name: openai-route
      matches:
      - path:
          pathPrefix: /v1
      policies:
        backendAuth:
          key: "$OPENAI_API_KEY"
      backends:
      - ai:
          name: openai
          provider:
            openAI: {}
YAML
fi

echo "challenge 2 setup complete"
