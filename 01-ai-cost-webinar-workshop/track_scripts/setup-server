#!/bin/bash

# Wait for instruqt bootstrap
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
  sleep 1
done

set -euo pipefail
set-workdir /root

# Store OpenAI key for use across challenges
if [ -n "${OPENAI_API_KEY:-}" ]; then
  echo "export OPENAI_API_KEY=${OPENAI_API_KEY}" >> ~/.bashrc
  echo "${OPENAI_API_KEY}" > /root/.openai-api-key
  echo "=== OpenAI API key stored ==="
else
  echo "=== WARNING: OPENAI_API_KEY not set ==="
fi

# Install agentgateway standalone binary (pinned)
echo "=== Installing agentgateway v1.3.1 ==="
curl -sL https://agentgateway.dev/install | bash -s -- --version 1.3.1
ln -sf "$(command -v agentgateway || echo /usr/local/bin/agentgateway)" /usr/local/bin/agentgateway 2>/dev/null || true

# Install uv (drives the OpenAI CLI and the mock-data generator) and expose it on
# the system PATH so non-interactive challenge scripts can find it.
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
ln -sf "$HOME/.local/bin/uv" /usr/local/bin/uv 2>/dev/null || true
ln -sf "$HOME/.local/bin/uvx" /usr/local/bin/uvx 2>/dev/null || true
export PATH="$HOME/.local/bin:$PATH"

# Official OpenAI CLI via uv (this image has no pip). Pin to 1.x — the 2.x package
# dropped the `openai` CLI entrypoint, so `openai<2` is required to get the binary.
uv tool install 'openai<2' >/dev/null 2>&1 || true
ln -sf "$HOME/.local/bin/openai" /usr/local/bin/openai 2>/dev/null || true

# sqlite3 for the fleet-analysis challenge (defensive; jq is already on the image).
command -v sqlite3 >/dev/null 2>&1 || { apt-get update -y >/dev/null 2>&1 && apt-get install -y sqlite3 >/dev/null 2>&1; } || true

# Stage workshop files onto the VM. Instruqt assets become markdown URLs (not VM
# files), so the cost catalog and the request-log generator are provisioned here.
mkdir -p /root/costs /root/data

# Provision the model cost catalog at /root/costs/base-costs.json. Best effort:
# briefly bootstrap agentgateway (no config) which writes the full ~846-model
# catalog, polling for it. Guaranteed fallback: a small deterministic catalog
# covering the models this track uses. Either way the file exists and prices calls.
( nohup agentgateway >/tmp/agw-bootstrap.log 2>&1 & )
for i in $(seq 1 30); do
  [ -s /root/.config/agentgateway/base-costs.json ] && { cp /root/.config/agentgateway/base-costs.json /root/costs/base-costs.json; break; }
  sleep 1
done
pkill -f "agentgateway" 2>/dev/null || true; sleep 1
if [ ! -s /root/costs/base-costs.json ]; then
cat > /root/costs/base-costs.json <<'JSON'
{ "providers": { "openai": { "models": {
  "gpt-4o-mini":  { "rates": { "input": "0.15", "output": "0.60" } },
  "gpt-4o":       { "rates": { "input": "2.50", "output": "10.00" } },
  "gpt-4.1":      { "rates": { "input": "2.00", "output": "8.00" } },
  "gpt-4.1-mini": { "rates": { "input": "0.40", "output": "1.60" } } } } } }
JSON
fi
echo "base-costs.json provisioned: $(wc -c < /root/costs/base-costs.json 2>/dev/null || echo MISSING) bytes"

cat > /root/gen-mock-logs.py <<'PYEOF'
