#!/bin/bash
set -uo pipefail
if ! grep -q 'localRateLimit' /root/config.yaml 2>/dev/null; then
  fail-message "No token budget found. Add llm.policies.localRateLimit (type: tokens) to /root/config.yaml, then agw-restart."
  exit 1
fi
if ! grep -q 'model: gpt-4o-mini' /root/config.yaml 2>/dev/null; then
  fail-message "No approved-model pin found. Set params.model: gpt-4o-mini on your model so expensive models can't be used, then agw-restart."
  exit 1
fi
if ! agentgateway -f /root/config.yaml --validate-only >/dev/null 2>&1; then
  fail-message "Config doesn't validate. Run: agentgateway -f /root/config.yaml --validate-only"
  exit 1
fi
echo "Governance in place: per-gateway token budget + approved-model pin."
