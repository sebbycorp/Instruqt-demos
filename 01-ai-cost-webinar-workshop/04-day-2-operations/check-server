#!/bin/bash
set -uo pipefail
if ! pgrep -f "agentgateway -f /root/config.yaml" >/dev/null; then
  fail-message "The gateway isn't running, so the UI won't load. Start it: agw-restart"
  exit 1
fi
ui=$(curl -s -o /dev/null -w '%{http_code}' http://localhost:15000/ui)
if [ "$ui" != "200" ]; then
  fail-message "The Agentgateway UI isn't reachable on :15000/ui (got HTTP $ui). Ensure config.adminAddr is 0.0.0.0:15000 and the gateway restarted."
  exit 1
fi
code=$(curl -s -o /dev/null -w '%{http_code}' http://localhost:4000/v1/chat/completions -H 'Content-Type: application/json' \
  -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"ping"}],"max_tokens":5}')
if [ "$code" != "200" ]; then
  fail-message "A test chat through the gateway returned HTTP $code — the UI's data pages need a working model on :4000."
  exit 1
fi
echo "Gateway + UI are live — explore Costs, Logs, Analytics, Raw Configuration, and Client Setup."
