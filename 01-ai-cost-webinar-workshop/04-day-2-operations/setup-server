#!/bin/bash
set -euo pipefail
# Leave a "broken" alternate config for the learner to diagnose. It is valid YAML
# but the model has NO apiKey, so upstream calls 401 — a realistic misconfig to
# find via the logs and config_dump.
cat > /root/config.broken.yaml <<'YAML'
config:
  adminAddr: "0.0.0.0:15000"
  database:
    url: "sqlite:///root/data/data.db"
  modelCatalog:
    - file: /root/costs/base-costs.json
llm:
  port: 4000
  models:
  - name: "*"
    provider: openAI
frontendPolicies:
  http:
    maxBufferSize: 33554432
YAML
echo "challenge 4 setup complete"
