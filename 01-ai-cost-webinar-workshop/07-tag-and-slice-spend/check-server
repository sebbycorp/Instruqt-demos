#!/bin/bash
set -uo pipefail
if ! grep -q 'llm.cost.total' /root/config.yaml 2>/dev/null; then
  fail-message "No CEL cost expression in /root/config.yaml. Add config.logging.fields.add (and metrics.fields.add) using llm.cost.total, then agw-restart."
  exit 1
fi
# Send a request, then poll the log for the custom cost field (avoids log-flush races).
curl -s http://localhost:4000/v1/chat/completions -H 'Content-Type: application/json' \
  -d '{"model":"openai/gpt-4o-mini","messages":[{"role":"user","content":"ping"}],"max_tokens":5}' >/dev/null 2>&1
for i in $(seq 1 12); do
  grep -q 'cost_usd=' /root/agentgateway.log 2>/dev/null && break
  sleep 1
done
if ! grep -q 'cost_usd=' /root/agentgateway.log 2>/dev/null; then
  fail-message "The custom cost field isn't appearing in the log. Ensure config.logging.fields.add has cost_usd: \"llm.cost.total\" and the gateway restarted (agw-restart), then send a request."
  exit 1
fi
echo "Spend is tagged and sliced by cost — CEL fields are in your logs and metrics."
