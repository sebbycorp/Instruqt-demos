#!/bin/bash
set -euo pipefail

# The MCP backend uses `npx @modelcontextprotocol/server-everything`, so Node must
# be present. Install it if missing (try apt, then the NodeSource convenience script).
if ! command -v npx >/dev/null 2>&1; then
  echo "=== npx not found; installing Node.js ==="
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update -y >/dev/null 2>&1 || true
    apt-get install -y nodejs npm >/dev/null 2>&1 || true
  fi
  if ! command -v npx >/dev/null 2>&1; then
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - >/dev/null 2>&1 || true
    apt-get install -y nodejs >/dev/null 2>&1 || true
  fi
fi

if command -v npx >/dev/null 2>&1; then
  echo "node: $(node --version 2>/dev/null || echo unknown)"
  # Warm the MCP server package so the first proxied call isn't slow.
  (npx -y @modelcontextprotocol/server-everything --help >/dev/null 2>&1 &) || true
else
  echo "WARNING: npx still unavailable; the MCP route will load but tool calls may fail."
fi

echo "challenge 6 setup complete"
