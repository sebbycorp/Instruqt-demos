#!/bin/bash
set -uo pipefail
if ! grep -q 'provider: openAI' /root/agentgateway/config.yaml 2>/dev/null && ! grep -q 'openai/\*' /root/agentgateway/config.yaml 2>/dev/null; then
  fail-message "No OpenAI model in /root/agentgateway/config.yaml. Add the llm.models entry, then reload the gateway (pkill + nohup)."
  exit 1
fi
# Poll :4000 — a reloaded process needs a moment to bind.
code=000
for i in $(seq 1 30); do
  code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 8 http://localhost:4000/v1/chat/completions \
    -H 'Content-Type: application/json' \
    -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"ping"}],"max_tokens":5}' 2>/dev/null)
  [ "$code" = "200" ] && break
  sleep 1
done
if [ "$code" != "200" ]; then
  echo "--- agw.log tail ---"; tail -15 /root/agentgateway/agw.log 2>/dev/null
  fail-message "A test call to :4000 returned HTTP $code. Ensure the model's apiKey is \$OPENAI_API_KEY and the gateway was reloaded."
  exit 1
fi
# Confirm the call was logged to the external SQLite DB.
rows=$(sqlite3 /data/data.db "SELECT COUNT(*) FROM request_logs;" 2>/dev/null || echo 0)
if [ -z "${rows:-}" ] || ! [ "$rows" -ge 1 ] 2>/dev/null; then
  fail-message "No rows in /data/data.db request_logs yet. Send a call through :4000, then re-check."
  exit 1
fi
echo "LLM call routed through :4000 and logged to the external SQLite DB ($rows rows in request_logs)."
