#!/bin/bash
set -uo pipefail
export OPENAI_API_KEY="${OPENAI_API_KEY:-$(cat /root/.openai-api-key 2>/dev/null)}"
mkdir -p /data; chmod -R 777 /data
cat > /root/agentgateway/config.yaml <<'YAML'
config:
  adminAddr: "0.0.0.0:15000"
  database:
    url: "sqlite:///data/data.db"
  modelCatalog:
    - file: /root/agentgateway/base-costs.json
llm:
  port: 4000
  policies:
    cors:
      allowOrigins: ["*"]
      allowHeaders: ["*"]
      allowMethods: ["GET","POST","OPTIONS"]
  models:
  - name: "openai/*"
    provider: openAI
    params:
      model: gpt-4.1-nano
      apiKey: "$OPENAI_API_KEY"
frontendPolicies:
  http:
    maxBufferSize: 33554432
YAML
pkill -f "agentgateway -f /root/agentgateway/config.yaml" 2>/dev/null || true
sleep 1
nohup agentgateway -f /root/agentgateway/config.yaml > /root/agentgateway/agw.log 2>&1 &
sleep 4
# Send a call so request_logs has at least one row.
curl -s -o /dev/null http://localhost:4000/v1/chat/completions \
  -H 'Content-Type: application/json' \
  -d '{"model":"openai/gpt-4.1-nano","messages":[{"role":"user","content":"hello"}],"max_tokens":10}'
sleep 1
echo "solve: model added, call sent, logged to /data/data.db"
