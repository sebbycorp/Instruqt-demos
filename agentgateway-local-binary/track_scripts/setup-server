#!/bin/bash

# Wait for instruqt bootstrap
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
  sleep 1
done

set -euo pipefail
set-workdir /root

# --- OpenAI key (Instruqt secret) available to the terminal + the gateway ---
if [ -n "${OPENAI_API_KEY:-}" ]; then
  echo "export OPENAI_API_KEY=${OPENAI_API_KEY}" >> ~/.bashrc
  echo "${OPENAI_API_KEY}" > /root/.openai-api-key
  echo "=== OpenAI API key stored ==="
else
  echo "=== WARNING: OPENAI_API_KEY not set ==="
fi

# --- Install the Agentgateway binary (pinned). Runs as root here, so no sudo issue. ---
echo "=== Installing agentgateway v1.3.1 ==="
curl -sL https://agentgateway.dev/install | bash -s -- --version 1.3.1
ln -sf "$(command -v agentgateway || echo /usr/local/bin/agentgateway)" /usr/local/bin/agentgateway 2>/dev/null || true
agentgateway --version 2>/dev/null | head -2 || echo "WARNING: agentgateway not runnable"

# sqlite3 for inspecting the external DB (defensive; usually present).
command -v sqlite3 >/dev/null 2>&1 || { apt-get update -y >/dev/null 2>&1 && apt-get install -y sqlite3 >/dev/null 2>&1; } || true

# --- App dir (config + cost catalog) and the EXTERNAL database dir (/data) ---
mkdir -p /root/agentgateway /data
chmod -R 777 /data

