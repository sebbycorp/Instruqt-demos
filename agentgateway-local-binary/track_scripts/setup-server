# Minimal config (no models yet) pointing at the EXTERNAL on-disk SQLite database.
# sqlite:///data/data.db  ==  absolute /data/data.db (3 slashes). All paths are absolute,
# so `agentgateway -f /root/agentgateway/config.yaml` works from any directory.
cat > /root/agentgateway/config.yaml <<'YAML'
# Minimal Agentgateway config — boots the gateway + UI with no models yet.
# The request database is an external SQLite file at /data/data.db.
config:
  adminAddr: "0.0.0.0:15000"
  database:
    url: "sqlite:///data/data.db"
  modelCatalog:
    - file: /root/agentgateway/base-costs.json
llm:
  port: 4000
  policies:
    cors:
      allowOrigins: ["*"]
      allowHeaders: ["*"]
      allowMethods: ["GET","POST","OPTIONS"]
  models: []
frontendPolicies:
  http:
    maxBufferSize: 33554432
YAML

# Convenience PATH for the terminal. No command aliases — the labs use the real
# agentgateway / nohup / pkill commands directly.
cat >> ~/.bashrc <<'RC'
