#!/bin/bash
set -uo pipefail
# Track setup already installed the binary and staged /root/agentgateway + /data.
# Be defensive in case the challenge is started in isolation.
command -v agentgateway >/dev/null 2>&1 || { curl -sL https://agentgateway.dev/install | bash -s -- --version 1.3.1; }
mkdir -p /root/agentgateway /data; chmod -R 777 /data
[ -f /root/agentgateway/config.yaml ] || echo "WARNING: config.yaml missing (track setup-server should have created it)"
echo "challenge 1 setup complete"
