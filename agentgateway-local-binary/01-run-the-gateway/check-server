#!/bin/bash
set -uo pipefail
if ! pgrep -f "agentgateway -f /root/agentgateway/config.yaml" >/dev/null; then
  fail-message "Agentgateway isn't running. Start it: nohup agentgateway -f /root/agentgateway/config.yaml > /root/agentgateway/agw.log 2>&1 &"
  exit 1
fi
# Poll the admin API (a freshly started process needs a moment to bind).
code=000
for i in $(seq 1 30); do
  code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 http://localhost:15000/config_dump 2>/dev/null)
  [ "$code" = "200" ] && break
  sleep 1
done
if [ "$code" != "200" ]; then
  echo "--- agw.log tail ---"; tail -15 /root/agentgateway/agw.log 2>/dev/null
  fail-message "The admin API on :15000 didn't return 200 (last: HTTP $code). Check /root/agentgateway/agw.log."
  exit 1
fi
if [ ! -f /data/data.db ]; then
  fail-message "The external SQLite database /data/data.db was not created. Confirm the config 'database.url' is sqlite:///data/data.db and that /data exists."
  exit 1
fi
echo "Gateway is running on :15000 and writing to the external SQLite DB at /data/data.db."
