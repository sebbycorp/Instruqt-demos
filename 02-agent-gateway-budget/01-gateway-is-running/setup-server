#!/bin/bash
set -euxo pipefail

# Wait for the control plane and data plane to be ready
kubectl -n agentgateway-system wait --for=condition=available deployment/enterprise-agentgateway --timeout=180s
kubectl -n agentgateway-system wait --for=condition=Available deployment -l app.kubernetes.io/name=agentgateway --timeout=180s || true

echo "Challenge 1 setup complete"
